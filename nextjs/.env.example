# Credentials (IAM user with permissions for Cognito, DynamoDB, S3, SES, EC2, MediaLive, Lambda, SSM)
VOID_REGION=us-east-2
VOID_ACCESS_KEY_ID=
VOID_SECRET_ACCESS_KEY=

# Cognito
COGNITO_USER_POOL_ID=us-east-2_xxxxxxxxx
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=

# DynamoDB table names
DYNAMO_EVENTS_TABLE=VoidEvents
DYNAMO_NEWSLETTERS_TABLE=VoidNewsletters
DYNAMO_AUDIT_TABLE=VoidAuditLogs
DYNAMO_SENDS_TABLE=VoidEmailSends
DYNAMO_TRACKING_TABLE=VoidTracking
DYNAMO_BROADCAST_TABLE=VoidBroadcast
DYNAMO_PLAYERS_TABLE=VoidPlayers
DYNAMO_GAMES_TABLE=VoidGames
DYNAMO_GAME_PLAYERS_TABLE=VoidGamePlayers
DYNAMO_POINTS_TABLE=VoidPoints
DYNAMO_POINT_EVENTS_TABLE=VoidPointEvents

# S3
S3_BUCKET_NAME=
NEXT_PUBLIC_S3_BASE_URL=https://your-bucket-name.s3.us-east-2.amazonaws.com

# SES
SES_FROM_EMAIL=newsletter@yourdomain.com
SES_CONTACT_LIST_NAME=void-ultimate

# TOTP secret for email send 2FA (base32, compatible with Google Authenticator / Authy)
# Generate with: node -e "const {authenticator} = require('otplib'); console.log(authenticator.generateSecret())"
TOTP_SECRET=

# Base URL for server-side fetch calls (no trailing slash)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Production: NEXT_PUBLIC_BASE_URL=https://yourdomain.com

# WebSocket server
WS_INTERNAL_SECRET=
# For local dev point at a local WS server:
# WS_SERVER_URL=http://localhost:3000
# NEXT_PUBLIC_WS_HOST=localhost:3000
WS_SERVER_URL=http://live.yourdomain.com:3000
NEXT_PUBLIC_WS_HOST=live.yourdomain.com:3000

# Lambda worker function names (set after first GitHub Actions deploy)
BROADCAST_WORKER_FUNCTION_NAME=
LIVE_SERVER_WORKER_FUNCTION_NAME=
